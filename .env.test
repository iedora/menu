# Used by Playwright's webServer and global-setup. NEVER point at the dev DB.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/metamenu_test
BETTER_AUTH_SECRET=test-secret-do-not-use-in-prod-test-secret-do-not-use-in-prod
BETTER_AUTH_URL=http://localhost:3000
DISABLE_RATE_LIMIT=true
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=metamenu-test
