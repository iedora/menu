{
  "name": "@iedora/design-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Iedora editorial design system — paper, ink, cinnabar.",
  "sideEffects": [
    "./src/styles.css",
    "./src/tokens.css",
    "./src/fonts.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./tokens.css": "./src/tokens.css",
    "./fonts.css": "./src/fonts.css"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "radix-ui": "^1.4.3"
  }
}
