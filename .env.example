# Single .env.example for both local dev and deploy.
#
# Local dev:  copy to .env.local   (gitignored; loaded by Next.js)
# Deploy:     copy to .env         (gitignored; loaded by Next.js AND Kamal)
#
# At dev time, .env.local overrides .env — so you can keep prod values in .env
# and only override the local-dev keys (DATABASE_URL, etc.) in .env.local.

# ── Next.js runtime (dev = local services; prod = Kamal-managed containers) ──

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/metamenu
BETTER_AUTH_SECRET=                  # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000

REDIS_URL=redis://localhost:6379

# S3-compatible: LocalStack in dev, MinIO accessory in prod.
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=metamenu

# Multi-instance prod only — generate with: openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
# DEPLOYMENT_VERSION=

# ── Deploy-only (Kamal + Tofu — leave blank for local dev) ───────────────────

# Cloudflare — dashboard right sidebar + Profile → API Tokens.
# Token scopes: Account · Cloudflare Tunnel · Edit, Zone · DNS · Edit (scoped),
# Account · Account Settings · Read.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Public app hostname (must be a subdomain of your Cloudflare zone).
# Assets are served from `assets.<rest-of-hostname>` automatically.
PUBLIC_HOSTNAME=menu.example.com

# Homelab/cloud box — IP or hostname. Kamal connects as root with SSH-key-only
# login (canonical Kamal 2 convention; ssh.user is hardcoded to root in
# config/deploy.yml, not configurable here).
ONPREM_HOST=192.168.50.53

# GitHub Container Registry — image is pushed to ghcr.io/$GHCR_USER/meta-menu.
# Run `gh auth refresh -s write:packages` once on your Mac.
GHCR_USER=

# Tofu state encryption (any string ≥ 16 chars; openssl rand -hex 32 is fine).
STATE_PASSPHRASE=

# Production-only secrets (openssl rand -hex 32 each; paste once, save to your
# password manager). At dev time .env.local overrides these.
POSTGRES_PASSWORD=
MINIO_ROOT_PASSWORD=
MINIO_ROOT_USER=metamenu
