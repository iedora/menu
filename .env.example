# Local-dev template for Next.js. Copy to .env.local (gitignored), fill in.
# Next loads `.env.local` first, then falls back to `.env` (not used in this repo).
#
# Infra/deploy secrets live in `.env.deploy` — see `.env.deploy.example`.
# That file is NOT loaded by Next.js, so Cloudflare/R2 creds never end up in
# `process.env` of a `bun run dev` process.

# Database — local Postgres from docker-compose.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/metamenu

# Better Auth — generate with: openssl rand -base64 32. MUST be identical
# to the value in products/genkan/.env.local so sessions issued by Genkan
# (auth.iedora.com) are recognised here.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Cookie domain shared by every iedora subdomain. Production: ".iedora.com".
# Leave blank in local dev — the browser refuses Domain= on localhost so the
# cookie stays host-only.
COOKIE_DOMAIN=

# Object storage — LocalStack from docker-compose.
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=metamenu

# Multi-instance prod only — generate with: openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
# DEPLOYMENT_VERSION=
