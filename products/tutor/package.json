{
  "name": "@iedora/product-tutor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tutor product — UI slices + shared domain over the tutor service (services/tutor in the tutor-marketplace repo). Being migrated into the platform monorepo as the tutor surface; routes live in apps/web/src/app/tutor/. This package starts with the pure display domain (pricing/status/time + enums) the UI needs.",
  "exports": {
    ".": "./src/index.ts",
    "./enums": "./src/enums.ts",
    "./domain/pricing": "./src/domain/pricing.ts",
    "./domain/status": "./src/domain/status.ts",
    "./domain/time": "./src/domain/time.ts",
    "./contracts/*": "./src/contracts/*.ts",
    "./api": "./src/api/index.ts",
    "./api/session": "./src/api/session.ts",
    "./auth": "./src/auth/index.ts",
    "./auth/config": "./src/auth/config.ts",
    "./auth/session": "./src/auth/session.ts"
  },
  "scripts": {
    "typecheck": "tsgo --build",
    "lint": "eslint --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "dependencies": {
    "@iedora/auth-sdk-nextjs": "^0.3.0",
    "server-only": "^0.0.1",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "next": "catalog:",
    "react": "catalog:"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@types/node": "^22.19.19",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
