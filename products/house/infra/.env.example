# House (iedora.com) deploy-time config. Copy to `infra/.env` (gitignored).
#
# Three of these values are shared with the menu product's BWS access —
# in a single-developer setup it's fine to copy/paste them across both
# products. (One BWS project unlocks both products' secrets.)
#
# Loaded by `bin/with-secrets`. The justfile's `set dotenv-load := true`
# also auto-loads this file.

# Cloudflare account ID — dashboard → right sidebar.
CLOUDFLARE_ACCOUNT_ID=

# ── Bitwarden Secrets Manager ────────────────────────────────────────────────
# Machine-account token + project UUID that unlocks the BWS vault.
# These are the SAME values used by products/menu/infra/.env — one BWS
# project holds every secret.
BWS_ACCESS_TOKEN=
BWS_PROJECT_ID=
