#!/bin/sh
# Wrap a command with secrets fetched from Bitwarden Secrets Manager,
# then exec the command in-place. The wrapped process inherits all BWS
# secrets as env vars + the TF_VAR_* aliases the house Tofu root expects.
#
# House needs less than menu — no PUBLIC_HOSTNAME, no ONPREM_HOST, no
# GHCR_USER (no app to deploy, no homelab to SSH to). It just provisions
# Cloudflare Pages + apex DNS via Tofu and uploads static files via wrangler.
#
# Why we DON'T use `bws run`: it spawns a child process that resets cwd
# and swallows the first line of stdout. We just `bws secret list -o env`
# + eval into the current shell, then exec — no subprocess oddities.
#
# Requires (loaded from infra/.env):
#   BWS_ACCESS_TOKEN          machine-account token (shared with menu's BWS)
#   BWS_PROJECT_ID            project UUID         (shared with menu's BWS)
#   CLOUDFLARE_ACCOUNT_ID     Cloudflare account ID
#
# Usage:
#   infra/bin/with-secrets <cmd> [args...]

set -eu

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
ENV_FILE="$SCRIPT_DIR/../.env"
if [ -f "$ENV_FILE" ] && [ -z "${BWS_ACCESS_TOKEN:-}" ]; then
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
fi

: "${BWS_ACCESS_TOKEN:?infra/.env missing BWS_ACCESS_TOKEN}"
: "${BWS_PROJECT_ID:?infra/.env missing BWS_PROJECT_ID}"

# Pull every BWS secret as KEY="value" and export into the current shell.
set -a
eval "$(bws secret list "$BWS_PROJECT_ID" -o env)"
set +a

# TF_VAR_* aliases — Tofu reads inputs from these specific names.
# House's Tofu root takes account_id + cloudflare_api_token +
# state_passphrase + zone_name. zone_name defaults to "iedora.com" via
# the variable's default, so no export needed unless overriding.
export TF_VAR_account_id="${CLOUDFLARE_ACCOUNT_ID:?CLOUDFLARE_ACCOUNT_ID missing}"
export TF_VAR_cloudflare_api_token="${CLOUDFLARE_API_TOKEN:?CLOUDFLARE_API_TOKEN missing in BWS}"
export TF_VAR_state_passphrase="${STATE_PASSPHRASE:?STATE_PASSPHRASE missing in BWS}"

exec "$@"
