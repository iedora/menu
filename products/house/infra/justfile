# House — iedora.com root brand site (Astro on Cloudflare Workers Static Assets).
#
# One Tofu root (`tofu/`) owns the entire deploy end-to-end since cloudflare/
# cloudflare provider v5.11+ added native directory asset uploads to
# `cloudflare_workers_script`. There is no wrangler in this workflow.
#
# `just` (no args) lists every recipe.

set dotenv-load := true

# Use the central Go-based wrapper at infra/bin/with-secrets. Single
# source of truth for BWS hydration + CF account discovery (the /zones
# lookup the central wrapper uses dodges the /accounts transient 503s
# that historically broke deploys here). Path is relative to this
# justfile's directory (products/house/infra).
tofu := "../../../infra/bin/with-secrets tofu -chdir=tofu"

_default:
    @just --list --unsorted

# Build the static site without deploying — fast local sanity check.
build:
    cd .. && bun run build

# Preview the built dist/ locally on http://localhost:3002.
preview:
    cd .. && bun run preview

# Full declarative deploy: build dist/, then `tofu apply` to upload the
# assets + reconcile the worker / custom-domain / TLS cert.
#
# Same recipe runs in CI (.github/workflows/house-deploy.yml). Idempotent —
# unchanged files skip upload via Cloudflare's asset hash check.
deploy: build
    {{tofu}} init -upgrade -input=false
    {{tofu}} apply -auto-approve

# Tear down: deletes the worker (which removes the custom domain + DNS
# record + TLS cert as part of the same destroy) via Tofu. Idempotent.
destroy:
    {{tofu}} destroy -auto-approve
