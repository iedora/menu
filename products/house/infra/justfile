# House — iedora.com root brand site.
#
# Layout: one Tofu root (tofu/ — Cloudflare Pages project + apex DNS + narrow
# pages-deploy token), one .env with shared BWS access, one `bin/with-secrets`
# that injects the BWS env + TF_VAR_* aliases for `tofu apply`.
#
# Content lives one level up at ../index.html (and anything else dropped in
# products/house/). `just deploy` runs tofu apply + wrangler upload in one
# go, with wrangler running under the narrow workload token (not bootstrap).
#
# `just` (no args) lists every recipe.

set dotenv-load := true

tofu := "bin/with-secrets tofu -chdir=tofu"

# Default: list recipes.
_default:
    @just --list --unsorted

# Pattern (community-canonical for terraform+CLI-tool): two tools, sequenced.
# Tofu reconciles CF resources; wrangler pushes content. Wrangler runs under
# the narrow Tofu-managed pages_deploy token (not the bootstrap CF token).
#
# Token rotation: edit BWS / `tofu apply -replace=cloudflare_api_token.X` →
# next `just deploy` picks up the regenerated value (both tools re-read BWS).

# Provision Pages project + apex DNS, then upload products/house/site/.
#
# Why `site/` as a subdir: `wrangler pages deploy` uploads everything in
# the directory it's pointed at, with a 25 MiB per-file ceiling and no
# `.gitignore`/`.assetsignore` support (the assetsignore feature is for
# Workers Static Assets, not Pages). If we pointed wrangler at the product
# root, it would try to upload `infra/.terraform/` (178 MiB Tofu provider).
# Sibling `site/` keeps deployables and deploy-machinery cleanly separated.
deploy:
    #!/usr/bin/env bash
    set -euo pipefail
    {{tofu}} init -upgrade -input=false >/dev/null
    {{tofu}} apply -auto-approve
    PROJECT=$({{tofu}} output -raw root_pages_project_name)
    DEPLOY_TOKEN=$({{tofu}} output -raw pages_deploy_token)
    CLOUDFLARE_API_TOKEN="$DEPLOY_TOKEN" \
      bunx wrangler@latest pages deploy ../site \
        --project-name="$PROJECT" --branch=main --commit-dirty=true

# Tear down the iedora.com Pages project + apex DNS.
destroy:
    {{tofu}} destroy -auto-approve
