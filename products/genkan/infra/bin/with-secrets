#!/bin/sh
# Wrap a command with secrets fetched from Bitwarden Secrets Manager.
# Identical pattern to products/menu/infra/bin/with-secrets — kept duplicated
# (not symlinked) so each product is independently appliable.
#
# Requires (from infra/.env):
#   BWS_ACCESS_TOKEN    machine-account token
#   BWS_PROJECT_ID      project UUID (same as menu's — shared secrets)
#   CLOUDFLARE_ACCOUNT_ID, PUBLIC_HOSTNAME  (Tofu inputs, non-secret)
#
# Usage:
#   infra/bin/with-secrets <cmd> [args...]
set -eu

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
ENV_FILE="$SCRIPT_DIR/../.env"
if [ -f "$ENV_FILE" ] && [ -z "${BWS_ACCESS_TOKEN:-}" ]; then
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
fi

: "${BWS_ACCESS_TOKEN:?infra/.env missing BWS_ACCESS_TOKEN}"
: "${BWS_PROJECT_ID:?infra/.env missing BWS_PROJECT_ID}"

# Bulk-fetch every secret in the project; `set -a` auto-exports each.
set -a
eval "$(bws secret list "$BWS_PROJECT_ID" -o env)"
set +a

# TF_VAR_* aliases for Tofu inputs.
export TF_VAR_account_id="${CLOUDFLARE_ACCOUNT_ID:?CLOUDFLARE_ACCOUNT_ID missing}"
export TF_VAR_cloudflare_api_token="${CLOUDFLARE_API_TOKEN:?CLOUDFLARE_API_TOKEN missing in BWS}"
export TF_VAR_state_passphrase="${STATE_PASSPHRASE:?STATE_PASSPHRASE missing in BWS}"
export TF_VAR_public_hostname="${PUBLIC_HOSTNAME:?PUBLIC_HOSTNAME missing}"

exec "$@"
