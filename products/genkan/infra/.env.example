# Deploy-time config for Tofu + Kamal — copy to `infra/.env` (gitignored).
#
# Genkan shares its Bitwarden Secrets Manager project + GHCR + homelab box
# with menu. The only product-specific value is PUBLIC_HOSTNAME.
#
# All PRODUCTION SECRETS (CLOUDFLARE_API_TOKEN, BETTER_AUTH_SECRET,
# POSTGRES_PASSWORD, GHCR_TOKEN, STATE_PASSPHRASE) live in BWS — this file
# carries only non-secret config + the BWS access token that unlocks the
# vault. Lose the laptop → re-clone, paste BWS_ACCESS_TOKEN, back up.

# ── Non-secret IDs (visible in DNS records anyway) ───────────────────────────

# Cloudflare account ID — dashboard → right sidebar. The zone ID is looked
# up automatically from PUBLIC_HOSTNAME below.
CLOUDFLARE_ACCOUNT_ID=

# Public hostname — auth.<zone>. The zone is everything after the first dot.
PUBLIC_HOSTNAME=auth.example.com

# Homelab / cloud box — same one menu deploys to. Kamal connects as root.
ONPREM_HOST=192.168.50.53

# GHCR username — image pushed to ghcr.io/$GHCR_USER/genkan.
GHCR_USER=

# ── Bitwarden Secrets Manager ────────────────────────────────────────────────
# SAME BWS project + access token as menu — genkan reads the shared secrets
# (POSTGRES_PASSWORD, BETTER_AUTH_SECRET, GHCR_TOKEN). Reuse the values from
# products/menu/infra/.env.
BWS_ACCESS_TOKEN=
BWS_PROJECT_ID=
