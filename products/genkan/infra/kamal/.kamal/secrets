# Kamal evaluates this file with shell semantics. KEY=value_or_$(expr).
# Working dir is infra/kamal/. No actual secret values — only references.
# Safe to commit.
#
# Sources:
#   Bitwarden Secrets Manager (shared project with menu) → app passwords
#   Tofu state (encrypted)                                → tunnel token
#   gh CLI (fallback only)                                → GHCR password
#
# BWS_PROJECT_ID and BWS_ACCESS_TOKEN come from infra/.env via justfile's
# `set dotenv-load`.

# Bulk-fetch every secret in the (shared) BWS project once.
SECRETS=$(kamal secrets fetch --adapter bitwarden-sm --from $BWS_PROJECT_ID all)

# Tofu state is encrypted (see infra/tofu/versions.tf). TF_VAR_state_passphrase
# is injected by `bin/with-secrets` (justfile wraps `kamal` in it), so every
# $(tofu output …) subshell inherits it.
TUNNEL_TOKEN=$(tofu -chdir=../tofu output -raw tunnel_token 2>/dev/null)

# GHCR — dedicated `write:packages` PAT, stored in BWS as GHCR_TOKEN.
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract GHCR_TOKEN $SECRETS)

# Shared with menu — same value, same Better Auth secret signs sessions on
# both apps so `.iedora.com` cookies are valid across the whole estate.
BETTER_AUTH_SECRET=$(kamal secrets extract BETTER_AUTH_SECRET $SECRETS)

# DATABASE_URL points at menu's Postgres accessory on the shared kamal Docker
# network. Genkan owns the `auth.*` schema; menu owns `menu.*`. POSTGRES_PASSWORD
# is the same value menu uses (one Postgres, two schemas).
POSTGRES_PASSWORD=$(kamal secrets extract POSTGRES_PASSWORD $SECRETS)
DATABASE_URL=postgres://postgres:$POSTGRES_PASSWORD@meta-menu-postgres:5432/metamenu
