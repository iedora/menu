# Database — shared with menu (and every other iedora product) in production.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/genkan

# Better Auth — generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of this service. Production: https://genkan.iedora.com
BETTER_AUTH_URL=http://localhost:3001

# Cookie domain shared by every iedora subdomain. Local dev keeps the cookie
# host-only (leave this blank); set to ".iedora.com" in production.
COOKIE_DOMAIN=

# Comma-separated list of origins that may call /api/auth/*. One per product
# you want signed-in to this Genkan instance. Add new products here.
# Local example: http://localhost:3000,http://localhost:3001
# Production:    https://menu.iedora.com,https://genkan.iedora.com
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001

# Where unauthenticated requests with no `return_to` should land after sign-in.
DEFAULT_RETURN_TO=http://localhost:3000

# Optional knobs --------------------------------------------------------------
# Disable Better Auth's per-IP rate limiter (E2E tests set this).
DISABLE_AUTH_RATE_LIMIT=false
