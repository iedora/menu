# Deploy-time config for Tofu + Kamal. Copy to `infra/.env` (gitignored).
#
# All PRODUCTION SECRETS live in Bitwarden Secrets Manager — this file
# holds only non-secret config + the BWS access token that unlocks the
# vault. Lose the laptop → re-clone the repo, paste BWS_ACCESS_TOKEN back,
# you're back up.
#
# Filename does NOT match Next.js's auto-load pattern (.env, .env.local,
# .env.<env>) AND lives outside the project root, so `bun run dev` can't
# see any of this even if it walked the tree.
#
# Loaded by the Makefile via `-include .env`.

# ── Non-secret IDs (visible in DNS records anyway) ───────────────────────────

# Cloudflare account ID — dashboard → right sidebar. The zone ID is looked
# up automatically from PUBLIC_HOSTNAME below, no need to specify it here.
CLOUDFLARE_ACCOUNT_ID=

# Public hostname (must be a subdomain of a Cloudflare-managed zone in the
# account above). Assets served from `assets.<rest-of-hostname>` automatically.
PUBLIC_HOSTNAME=menu.example.com

# Homelab / cloud box. Kamal connects as root with SSH-key-only login.
ONPREM_HOST=192.168.50.53

# GitHub Container Registry — your GH username; image pushed to
# ghcr.io/$GHCR_USER/meta-menu.
GHCR_USER=

# ── Bitwarden Secrets Manager ────────────────────────────────────────────────
# The ONE secret on disk. Generate via:
#   1. vault.bitwarden.com/#/sm → create project "meta-menu" → copy project UUID
#   2. Machine accounts → New → name "meta-menu-deploy" → add project with R/W
#   3. Access tokens → New → no expiry → copy the `0.xxx...` value
#
# Everything else (CLOUDFLARE_API_TOKEN, STATE_PASSPHRASE, BETTER_AUTH_SECRET,
# POSTGRES_PASSWORD, BACKUP_PASSPHRASE, GHCR_TOKEN) lives in BWS. See
# docs/deploy.md for the migration recipe.
BWS_ACCESS_TOKEN=
BWS_PROJECT_ID=

