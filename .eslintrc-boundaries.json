{
  "plugins": ["boundaries"],
  "settings": {
    "boundaries/elements": [
      { "type": "shared", "pattern": "shared/**" },
      { "type": "features", "pattern": "features/**", "capture": ["slice"] },
      { "type": "app", "pattern": "app/**" }
    ]
  },
  "rules": {
    "boundaries/element-types": "off",
    "boundaries/no-private": "off",
    "boundaries/no-unknown": "off"
  }
}
