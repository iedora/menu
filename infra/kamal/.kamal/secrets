# Kamal evaluates this file with shell semantics. KEY=value_or_$(expr).
# Working dir is infra/kamal/. No actual secret values — only references.
# Safe to commit.
#
# Sources:
#   Bitwarden Secrets Manager (project iedora-deploy) → infra passwords
#   Tofu state (encrypted)                            → R2 backup S3 keys
#
# BWS_PROJECT_ID and BWS_ACCESS_TOKEN come from infra/.env via the
# justfile's `set dotenv-load`.

SECRETS=$(kamal secrets fetch --adapter bitwarden-sm --from $BWS_PROJECT_ID all)

# GHCR — used by `kamal accessory boot backups` to pull the self-built
# backup image from ghcr.io/$GHCR_USER/iedora-backup:18.
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract INFRA_GHCR_TOKEN $SECRETS)

# Postgres root password — same value menu's and genkan's app containers
# use to compose their respective DATABASE_URLs.
POSTGRES_PASSWORD=$(kamal secrets extract INFRA_POSTGRES_PASSWORD $SECRETS)

# Backup R2 bucket — keys minted by infra/tofu/ (cloudflare_api_token.backups_r2).
S3_ACCESS_KEY_ID=$(tofu -chdir=../tofu output -raw backups_r2_access_key_id 2>/dev/null)
S3_SECRET_ACCESS_KEY=$(tofu -chdir=../tofu output -raw backups_r2_secret_access_key 2>/dev/null)

# GPG passphrase used by backup.sh to encrypt the dump before R2 upload.
PASSPHRASE=$(kamal secrets extract INFRA_BACKUP_PASSPHRASE $SECRETS)

# ── OpenObserve (shared observability backend) ───────────────────────────────
# R2 keys minted by infra/tofu/ (cloudflare_api_token.observability_r2).
# Tunnel token also from tofu state — same deploy host has Tofu, no need
# to write through to BWS like the per-product app tunnel tokens.
ZO_S3_ACCESS_KEY=$(tofu -chdir=../tofu output -raw observability_r2_access_key_id 2>/dev/null)
ZO_S3_SECRET_KEY=$(tofu -chdir=../tofu output -raw observability_r2_secret_access_key 2>/dev/null)

# cloudflared expects the connector token at $TUNNEL_TOKEN. The infra
# kamal config has no other tunnel — no naming collision. Per-product
# tunnel tokens (menu, genkan) live in their OWN secrets files.
TUNNEL_TOKEN=$(tofu -chdir=../tofu output -raw observability_tunnel_token 2>/dev/null)

# Root admin credentials. The UI uses these for human login AND every
# product's OTLP exporter signs ingest with `Authorization: Basic`
# base64(email:password). Rotate via `just infra::rotate-secret` — every
# product will need a redeploy to pick up the new OTEL_EXPORTER_OTLP_HEADERS.
ZO_ROOT_USER_EMAIL=$(kamal secrets extract INFRA_OPENOBSERVE_ROOT_USER_EMAIL $SECRETS)
ZO_ROOT_USER_PASSWORD=$(kamal secrets extract INFRA_OPENOBSERVE_ROOT_USER_PASSWORD $SECRETS)
