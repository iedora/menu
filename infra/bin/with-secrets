#!/bin/sh
# Wrap a command with secrets fetched from Bitwarden Secrets Manager.
#
# Strategy: `bws run` injects every secret in the project as an env var into
# the wrapped process. We then re-export the ones Tofu wants under TF_VAR_
# names. Kamal reads its `.kamal/secrets` which references the plain names
# ($BETTER_AUTH_SECRET, $POSTGRES_PASSWORD, etc.) directly from env — no
# adapter dance needed.
#
# Requires (loaded from infra/.env via the Makefile):
#   BWS_ACCESS_TOKEN    machine-account token
#   BWS_PROJECT_ID      project UUID
#   CLOUDFLARE_ACCOUNT_ID, CLOUDFLARE_ZONE_ID, PUBLIC_HOSTNAME  (Tofu inputs,
#                       non-secret so they live in .env not BWS)
#
# Usage:
#   infra/bin/with-secrets <cmd> [args...]
#
# Example:
#   infra/bin/with-secrets tofu -chdir=tofu apply -auto-approve
set -eu

# When invoked directly (not from Make), source infra/.env ourselves so the
# wrapper is self-contained. The Makefile already exports these via -include,
# so this is a no-op there.
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
ENV_FILE="$SCRIPT_DIR/../.env"
if [ -f "$ENV_FILE" ] && [ -z "${BWS_ACCESS_TOKEN:-}" ]; then
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
fi

: "${BWS_ACCESS_TOKEN:?infra/.env missing BWS_ACCESS_TOKEN}"
: "${BWS_PROJECT_ID:?infra/.env missing BWS_PROJECT_ID}"

# `bws run` fetches every secret in the project and exports it as an env var
# named after the secret's Key. We chain through `_inject-tf-vars` (a sibling
# helper) which adds the TF_VAR_* aliases Tofu expects, then exec's the user's
# command. Two-script split avoids `bws run -- sh -c 'script' arg` mis-parsing.
exec bws run --project-id "$BWS_PROJECT_ID" -- "$SCRIPT_DIR/_inject-tf-vars" "$@"
