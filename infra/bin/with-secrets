#!/usr/bin/env bash
# Transparent wrapper for the Go with-secrets command at infra/cmd/with-secrets.
# Same shape as bin/iedora and bin/zitadel-grant — `go run` compiles once into
# the user's GOCACHE; subsequent invocations reuse the cached binary.
#
# Used by:
#   - bin/iedora (layered on top to hydrate BWS env before exec'ing iedora)
#   - `just with-secrets <cmd>` (root justfile recipe)
#   - CI workflows (`.github/workflows/infra-deploy.yml` etc.) for raw tofu calls
#   - per-product justfiles (products/house/infra → `../../../infra/bin/with-secrets`)
#   - ad-hoc operator one-liners (`bin/with-secrets tofu -chdir=tofu state list`)
#
# CWD trap: `go run -C INFRA_DIR ./cmd/with-secrets` inherits go run's cwd
# (= INFRA_DIR) into the spawned binary. Tools like `tofu -chdir=tofu` then
# resolve against INFRA_DIR instead of the operator's cwd — so house's
# `tofu -chdir=tofu apply` would silently target the central state. We
# forward the operator's original cwd as ORIG_PWD; the Go side chdirs back
# to it before exec'ing the target command.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INFRA_DIR="$(dirname "$DIR")"

exec env ORIG_PWD="$PWD" go run -C "$INFRA_DIR" ./cmd/with-secrets "$@"
