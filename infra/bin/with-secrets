#!/usr/bin/env bash
# Transparent wrapper pointing to the idiomatic Go with-secrets command.
# This keeps all local justfile tasks, docs, and remote CI/CD workflows green.
set -euo pipefail

# Resolve the absolute path to the infra directory
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INFRA_DIR="$(dirname "$DIR")"

# Execute the Go command directly using go run from the infra directory,
# forwarding all CLI arguments.
exec go run -C "$INFRA_DIR" ./cmd/with-secrets "$@"
