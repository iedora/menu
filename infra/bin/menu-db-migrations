#!/usr/bin/env bash
# Transparent wrapper for the Go menu-db-migrations command at
# infra/cmd/menu-db-migrations. Same shape as the other bin/ shims —
# `go run` compiles once into GOCACHE; subsequent invocations reuse
# the cached binary.
#
# Stage 3 configurator. Invoked by `task app:apply` via the
# `appConfigurators` registry in `infra/cmd/iedora/configurators.go`.
# Reads `MENU_IMAGE_SHA` from env to know which image's migration
# bundle to apply.
#
# Ad-hoc use:
#   MENU_IMAGE_SHA=latest infra/bin/with-secrets --stage app -- infra/bin/menu-db-migrations
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INFRA_DIR="$(dirname "$DIR")"

exec go run -C "$INFRA_DIR" ./cmd/menu-db-migrations "$@"
