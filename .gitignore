# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Vitest
.vitest-cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.production
.env.*.local
!.env.example
!.env.test
# Infra .env (gitignored); the example file IS tracked.
infra/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/
/playwright/.auth/

# Claude Code — local user settings (skills are shared)
.claude/settings.local.json
.claude/

# Infra — tofu state, never in git
infra/**/*.iso
infra/**/.terraform/
infra/**/terraform.tfstate
infra/**/terraform.tfstate.backup
infra/**/terraform.tfstate.d/
infra/**/terraform.tfvars
# .terraform.lock.hcl SHOULD be committed — pins provider versions

# Kamal — .kamal/secrets is committed (only references, no values). Real
# secret material lives in infra/.env (gitignored above).

# Backup artefacts — `make restore` and ad-hoc pg_dump leave these in cwd.
# Database dumps are the most sensitive payload in the repo; never commit one
# even if it lands gpg-encrypted (the file shape leaks volume + schedule).
*.dump
*.dump.gpg
*.sql.gz
*.bak
