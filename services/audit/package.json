{
  "name": "@iedora/service-audit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Audit service (Hono/Bun): the read/query API over the append-only audit_log. Migration pilot — the smallest, lowest-risk service to port first.",
  "exports": {
    "./app": "./src/app.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "migrate": "bun run src/migrate.ts",
    "db:codegen": "kysely-codegen --dialect postgres --url ${AUDIT_DATABASE_URL:-postgres://iedora:iedora@localhost:55433/audit} --exclude-pattern '(schema_migrations|audit_log_default)' --out-file src/db.generated.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src --cache --cache-location node_modules/.cache/.eslintcache",
    "test": "bun test"
  },
  "dependencies": {
    "@iedora/contracts": "workspace:*",
    "@iedora/server-kit": "workspace:*",
    "@hono/zod-validator": "catalog:",
    "hono": "catalog:",
    "kysely": "catalog:"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@types/bun": "catalog:",
    "eslint": "catalog:",
    "jose": "catalog:",
    "kysely-codegen": "catalog:",
    "pg": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
