{
  "name": "@iedora/service-audit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Audit service (Hono/Bun): ingests audit events from every producer over HTTP and serves the read/query API over the append-only audit_log. Standalone, framework-direct (@iedora/service-kit + @iedora/audit).",
  "scripts": {
    "dev": "node --watch src/index.ts",
    "start": "node src/index.ts",
    "migrate": "node src/migrate.ts",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "dependencies": {
    "@hono/zod-validator": "catalog:",
    "@iedora/common": "workspace:*",
    "@iedora/db": "workspace:*",
    "@iedora/messaging": "workspace:*",
    "@iedora/service-kit": "workspace:*",
    "hono": "catalog:",
    "kysely": "catalog:",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "^8.11.10",
    "eslint": "catalog:",
    "jose": "catalog:",
    "postgres": "^3.4.5",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
