#!/usr/bin/env bash
set -euo pipefail

# Pre-deploy hook: corre Drizzle migrations contra a *nova* imagem antes de
# qualquer container novo entrar em traffic. Falha aborta o deploy inteiro
# (a app antiga continua intacta com a schema antiga).
#
# Para o primeiro deploy num servidor novo, NÃO usar este hook — usar
# `make kamal-bootstrap` que pré-arranca os accessories e corre o setup
# com --skip-hooks. Ref: basecamp/kamal#526.

# Rollback: imagem antiga, schema antiga já está correcta.
if [[ "${KAMAL_COMMAND:-}" == "rollback" ]]; then
  echo "[pre-deploy] rollback detected, skipping migrations"
  exit 0
fi

# Sem KAMAL_VERSION não conseguimos targetar uma imagem específica.
if [[ -z "${KAMAL_VERSION:-}" ]]; then
  echo "[pre-deploy] no KAMAL_VERSION, skipping migrations"
  exit 0
fi

echo "[pre-deploy] running Drizzle migrations against ${KAMAL_VERSION}"

kamal app exec \
  --primary \
  --version "$KAMAL_VERSION" \
  "node scripts/migrate.mjs"
