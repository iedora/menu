# E2E fixtures — superset env for the unified `apps/web` test build.
#
# Every product runs against the same Next.js shell, so the build needs
# every env var any route consumes — even ones a given suite doesn't
# exercise. `bun --env-file=.env.test` loads this for `next build`,
# Playwright workers, and the better-auth server.

NODE_ENV=production

# Postgres — one server, three databases:
#   menu_test     → menu's drizzle schema (products/menu/drizzle/)
#   core_test     → better-auth schema (packages/auth/drizzle/)
#   imopush_test  → imopush's drizzle schema (products/imopush/drizzle/)
MENU_DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/menu_test
CORE_DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/core_test
IMOPUSH_DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/imopush_test

# better-auth
CORE_SECRET=test-iedora-auth-secret-do-not-use-in-prod-32chars
CORE_BASE_URL=http://localhost:3000
CORE_TRUSTED_ORIGINS=http://localhost:3000
CORE_COOKIE_DOMAIN=localhost
NEXT_PUBLIC_CORE_URL=http://localhost:3000/core
NEXT_PUBLIC_MENU_URL=http://localhost:3000
NEXT_PUBLIC_IMOPUSH_URL=http://localhost:3000/imopush

DISABLE_RATE_LIMIT=true

# S3 — adobe/s3mock (LocalStack :latest requires a paid licence as of 2026).
S3_ENDPOINT=http://localhost:9090
S3_REGION=us-east-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=menu-test
